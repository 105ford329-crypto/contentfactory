              {
                "field": "should_publish",
                "condition": "equals",
                "value": "true"
              },
              {
                "field": "published",
                "condition": "notEquals",
                "value": "true"
              },
              {
                "field": "post_type",
                "condition": "equals",
                "value": "short"
              }
            ]
          }
        }
      },
      "id": "google-sheets-read-news",
      "name": "Get row(s) in sheet2",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [470, 500]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-items",
              "leftValue": "={{$json.length}}",
              "rightValue": "0",
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "filter-has-items",
      "name": "Filter1",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [690, 500]
    },
    {
      "parameters": {
        "jsCode": "// Получаем промпты из GitHub\nconst promptsUrl = $env.GITHUB_PROMPTS_URL || 'https://raw.githubusercontent.com/yourusername/ai-content-prompts/main/short-posts.json';\n\nconst response = await $http.request({\n  url: promptsUrl,\n  method: 'GET'\n});\n\nconst prompts = response.data;\n\n// Получаем статистику из Google Sheets для адаптации\nconst statsSheet = await $('Google Sheets').getNodeParameter('documentId');\nconst stats = await $('Google Sheets').getAll({\n  sheetName: 'post_statistics',\n  options: {\n    filters: [\n      { field: 'post_type', condition: 'equals', value: 'short' }\n    ]\n  }\n});\n\n// Анализируем, какие паттерны работают лучше\nconst patterns = {};\nstats.forEach(stat => {\n  const pattern = stat.pattern_type;\n  if (!patterns[pattern]) {\n    patterns[pattern] = { total: 0, engagement: 0, views: 0 };\n  }\n  patterns[pattern].total++;\n  patterns[pattern].engagement += stat.engagement_rate;\n  patterns[pattern].views += stat.views;\n});\n\n// Выбираем лучший паттерн\nlet bestPattern = null;\nlet bestScore = 0;\n\nfor (const [pattern, data] of Object.entries(patterns)) {\n  const avgEngagement = data.engagement / data.total;\n  const avgViews = data.views / data.total;\n  const score = avgEngagement * 0.6 + (avgViews / 1000) * 0.4; // Взвешенная оценка\n  \n  if (score > bestScore) {\n    bestScore = score;\n    bestPattern = pattern;\n  }\n}\n\n// Используем лучший паттерн или случайный, если статистики нет\nconst selectedPrompt = bestPattern && prompts[bestPattern] \n  ? prompts[bestPattern] \n  : prompts[Object.keys(prompts)[Math.floor(Math.random() * Object.keys(prompts).length)]];\n\nreturn {\n  json: {\n    prompt: selectedPrompt,\n    pattern_type: bestPattern || 'random',\n    news_items: $input.all()\n  }\n};"
      },
      "id": "code-get-prompts",
      "name": "Code5",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [910, 500]
    },
    {
