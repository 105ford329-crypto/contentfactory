    {
      "parameters": {
        "promptType": "define",
        "text": "={{$json.prompt}}\n\nИсточник:\nЗаголовок: {{$json.news_items[0].title}}\nКлючевые пункты: {{$json.news_items[0].key_points}}\nУгол подачи: {{$json.news_items[0].suggested_angle}}\n\nСгенерируй пост в формате JSON:\n{\n  \"text\": \"текст поста с эмодзи\",\n  \"hashtags\": [\"#ai\", \"#tech\"],\n  \"call_to_action\": \"призыв к действию\"\n}",
        "options": {
          "systemMessage": "Ты expert-копирайтер для соцсетей. Твои посты вирусные, провокационные и генерируют высокую вовлечённость. Используй данные о том, какие паттерны работают лучше."
        }
      },
      "id": "anthropic-generate",
      "name": "Code3",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1,
      "position": [1130, 500]
    },
    {
      "parameters": {
        "jsCode": "// Парсим ответ от LLM\nconst response = JSON.parse($input.item.json.response);\n\nreturn {\n  json: {\n    post_text: response.text,\n    hashtags: response.hashtags.join(' '),\n    call_to_action: response.call_to_action,\n    news_id: $input.item.json.news_items[0].id,\n    pattern_type: $input.item.json.pattern_type,\n    created_at: new Date().toISOString()\n  }\n};"
      },
      "id": "code-parse-response",
      "name": "Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1350, 500]
    },
