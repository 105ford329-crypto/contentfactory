        "specifyBody": "json",
        "jsonBody": "={\n  \"template_id\": \"YOUR_CREATOMATE_TEMPLATE_ID\",\n  \"modifications\": {\n    \"Video-1\": \"{{ $json.video_1 }}\",\n    \"Video-2\": \"{{ $json.video_2 }}\",\n    \"Video-3\": \"{{ $json.video_3 }}\",\n    \"Video-4\": \"{{ $json.video_4 }}\",\n    \"Hook-Text\": \"{{ $json.hook }}\",\n    \"Body-Text\": \"{{ $json.body }}\",\n    \"CTA-Text\": \"{{ $json.cta }}\",\n    \"Audio\": \"{{ $json.audio_url }}\"\n  }\n}"
      },
