    {
      "parameters": {
        "jsCode": "// Склейка видео - подготовка URL для Creatomate\nconst items = $input.all();\n\nconst videoUrls = [];\nlet audioUrl = '';\nlet fontUrl = '';\nlet originalData = {};\n\nfor (const item of items) {\n  const data = item.json;\n  \n  // Сохраняем оригинальные данные из очереди\n  if (data.id && data.full_script) {\n    originalData = {\n      id: data.id,\n      full_script: data.full_script,\n      hook: data.hook,\n      body: data.body,\n      cta: data.cta,\n      description: data.description,\n      hashtags: data.hashtags\n    };\n  }\n  \n  // Собираем URL видео\n  if (data.webContentLink && data.mimeType?.includes('video')) {\n    videoUrls.push(data.webContentLink);\n  }\n  \n  // Аудио\n  if (data.webContentLink && data.mimeType?.includes('audio')) {\n    audioUrl = data.webContentLink;\n  }\n  \n  // Шрифт\n  if (data.font_url) {\n    fontUrl = data.font_url;\n  }\n}\n\nreturn [{\n  json: {\n    ...originalData,\n    video_1: videoUrls[0] || '',\n    video_2: videoUrls[1] || '',\n    video_3: videoUrls[2] || '',\n    video_4: videoUrls[3] || '',\n    audio_url: audioUrl,\n    font_url: fontUrl,\n    total_videos: videoUrls.length\n  }\n}];"
      },
      "id": "concat-videos",
      "name": "Concat videos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2220, 500]
    },
