    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"anthropic/claude-3.5-sonnet\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Ты — копирайтер для коротких видео. Пишешь вовлекающие тексты для Reels/TikTok.\\n\\nСТИЛЬ (настрой под себя):\\n- Дружелюбный, экспертный тон\\n- Короткие предложения\\n- Вопросы к аудитории\\n- Практические советы\\n- Сильный CTA\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"На основе анализа трендов:\\n{{ $json.analysis }}\\n\\nПримеры успешных заголовков:\\n{{ $json.headlines_data }}\\n\\nСгенерируй 5 уникальных тем для рилсов.\\n\\nДля каждой:\\n1. hook - цепляющие первые 3 секунды\\n2. body - основной текст (30-60 сек)\\n3. cta - призыв к действию\\n4. description - описание поста\\n5. hashtags - 5-7 хэштегов\\n\\nВерни JSON массив.\"\n    }\n  ]\n}"
      },
      "id": "openrouter-generation",
      "name": "Basic LLM Chain",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2440, 400],
      "credentials": {
        "httpHeaderAuth": {
          "id": "OPENROUTER_CREDENTIALS_ID",
          "name": "OpenRouter API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Парсим ответ Claude\nconst response = $input.first().json;\nconst content = response.choices[0].message.content;\n\nlet topics = [];\ntry {\n  const jsonMatch = content.match(/\\[\\s*\\{[\\s\\S]*\\}\\s*\\]/);\n  if (jsonMatch) {\n    topics = JSON.parse(jsonMatch[0]);\n  } else {\n    topics = JSON.parse(content);\n  }\n} catch (e) {\n  return [{ json: { error: 'Parse failed', raw: content } }];\n}\n\nconst now = new Date().toISOString();\nreturn topics.map((topic, i) => ({\n  json: {\n    id: `topic_${Date.now()}_${i}`,\n    created_at: now,\n    status: 'pending',\n    ...topic,\n    full_script: `${topic.hook || ''} ${topic.body || ''} ${topic.cta || ''}`\n  }\n}));"
      },
