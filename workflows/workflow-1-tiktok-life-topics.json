    {
      "parameters": {
        "jsCode": "// Объединяем все паттерны в один массив для анализа\nconst items = $input.all();\n\nconst headlines = [];\nconst descriptions = [];\n\nfor (const item of items) {\n  const data = item.json;\n  if (data.source === 'tiktok_headlines' || data.source === 'tiktok_headlines_2') {\n    headlines.push({\n      text: data.text,\n      views: data.views,\n      likes: data.likes\n    });\n  } else if (data.source === 'instagram_descriptions') {\n    descriptions.push({\n      text: data.text,\n      views: data.views,\n      likes: data.likes\n    });\n  }\n}\n\n// Сортируем по просмотрам\nheadlines.sort((a, b) => b.views - a.views);\ndescriptions.sort((a, b) => b.views - a.views);\n\nconst topHeadlines = headlines.slice(0, 15).map((h, i) => \n  `${i+1}. [${h.views} views] ${h.text}`\n).join('\\n');\n\nconst topDescriptions = descriptions.slice(0, 10).map((d, i) => \n  `${i+1}. [${d.views} views] ${d.text}`\n).join('\\n');\n\nreturn [{\n  json: {\n    headlines_data: topHeadlines,\n    descriptions_data: topDescriptions,\n    total_headlines: headlines.length,\n    total_descriptions: descriptions.length\n  }\n}];"
      },
      "id": "code-prepare",
      "name": "Code - Подготовка",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"google/gemini-2.0-flash-001\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Ты — аналитик трендов социальных сетей. Анализируешь контент и выделяешь паттерны.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Проанализируй успешные посты конкурентов.\\n\\n## ЗАГОЛОВКИ (TikTok):\\n{{ $json.headlines_data }}\\n\\n## ОПИСАНИЯ (Instagram):\\n{{ $json.descriptions_data }}\\n\\nВыдели:\\n1. Топ-5 работающих тем\\n2. Паттерны хуков (первые слова)\\n3. Эмоциональные триггеры\\n4. Форматы которые залетают\\n5. Оптимальная структура\\n\\nОтвет в JSON.\"\n    }\n  ]\n}"
      },
