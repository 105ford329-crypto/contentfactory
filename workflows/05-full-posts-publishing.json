      "parameters": {
        "jsCode": "// Webhook от Threads с аналитикой\nconst data = $input.item.json.body;\n\nreturn {\n  json: {\n    threads_post_id: data.post_id,\n    views: data.impressions || 0,\n    likes: data.likes || 0,\n    comments: data.comments || 0,\n    shares: data.shares || 0,\n    engagement_rate: ((data.likes + data.comments * 2 + data.shares * 3) / data.impressions * 100) || 0,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
