    {
      "parameters": {
        "jsCode": "// Оптимальное время для постинга на основе статистики\nconst stats = await $('Google Sheets').getAll({\n  sheetName: 'post_statistics',\n  options: {}\n});\n\n// Анализируем, в какое время лучшая вовлеченность\nconst hourlyStats = {};\nstats.forEach(stat => {\n  const hour = new Date(stat.published_at).getHours();\n  if (!hourlyStats[hour]) {\n    hourlyStats[hour] = { total: 0, engagement: 0 };\n  }\n  hourlyStats[hour].total++;\n  hourlyStats[hour].engagement += stat.engagement_rate;\n});\n\n// Находим лучшее время\nlet bestHour = 12; // По умолчанию\nlet bestEngagement = 0;\n\nfor (const [hour, data] of Object.entries(hourlyStats)) {\n  const avgEngagement = data.engagement / data.total;\n  if (avgEngagement > bestEngagement) {\n    bestEngagement = avgEngagement;\n    bestHour = parseInt(hour);\n  }\n}\n\nconst currentHour = new Date().getHours();\nconst shouldPublishNow = Math.abs(currentHour - bestHour) <= 1;\n\nreturn {\n  json: {\n    ...($input.item.json),\n    best_hour: bestHour,\n    should_publish_now: shouldPublishNow,\n    current_hour: currentHour\n  }\n};"
      },
      "id": "code-optimal-time",
      "name": "Code2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 700]
    },
