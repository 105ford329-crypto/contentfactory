    {
      "parameters": {
        "jsCode": "// Анализируем эффективность паттерна\nconst post = $input.first().json;\nconst stats = $input.last().json;\n\n// Получаем все статистики этого паттерна\nconst allStats = await $('Google Sheets').getAll({\n  sheetName: 'post_statistics',\n  options: {\n    filters: [\n      { field: 'pattern_type', condition: 'equals', value: post.pattern_type }\n    ]\n  }\n});\n\n// Вычисляем среднюю эффективность\nconst avgEngagement = allStats.reduce((sum, s) => sum + s.engagement_rate, 0) / allStats.length;\n\n// Определяем, нужно ли адаптировать стратегию\nconst isPerforming = stats.engagement_rate > avgEngagement * 1.2; // На 20% лучше среднего\nconst isUnderperforming = stats.engagement_rate < avgEngagement * 0.8; // На 20% хуже среднего\n\nlet adaptation = null;\n\nif (isPerforming) {\n  adaptation = {\n    action: 'increase_frequency',\n    pattern: post.pattern_type,\n    reason: 'Паттерн показывает высокую эффективность',\n    multiplier: 1.5\n  };\n} else if (isUnderperforming) {\n  adaptation = {\n    action: 'decrease_frequency',\n    pattern: post.pattern_type,\n    reason: 'Паттерн показывает низкую эффективность',\n    multiplier: 0.5\n  };\n}\n\nif (adaptation) {\n  // Сохраняем адаптацию в GitHub для обновления промптов\n  return {\n    json: {\n      ...stats,\n      post_info: post,\n      adaptation: adaptation,\n      should_update_prompts: true\n    }\n  };\n}\n\nreturn {\n  json: {\n    ...stats,\n    post_info: post,\n    adaptation: null,\n    should_update_prompts: false\n  }\n};"
      },
      "id": "code-analyze-performance",
      "name": "Code2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 1100]
    },
