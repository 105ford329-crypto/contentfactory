    {
      "parameters": {
        "jsCode": "// Финальная обработка данных карусели\nconst item = $input.first().json;\n\n// Парсинг контента от LLM\nlet carouselContent;\ntry {\n  const llmResponse = $('Ajax Out').item.json.choices[0].message.content;\n  const jsonMatch = llmResponse.match(/\\{[\\s\\S]*\\}/);\n  carouselContent = jsonMatch ? JSON.parse(jsonMatch[0]) : { title: 'Карусель', slides: [] };\n} catch (e) {\n  carouselContent = { title: 'Карусель', slides: [], cta: 'Подпишись!', hashtags: [] };\n}\n\nreturn [{\n  json: {\n    title: carouselContent.title,\n    slides: carouselContent.slides,\n    cta: carouselContent.cta,\n    hashtags: carouselContent.hashtags,\n    topic: item.topic,\n    row_number: item.row_number\n  }\n}];"
      },
