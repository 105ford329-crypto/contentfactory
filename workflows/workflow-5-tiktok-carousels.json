    {
      "parameters": {
        "jsCode": "// Подготовка данных для генерации карусели\nconst item = $input.first().json;\n\nreturn [{\n  json: {\n    topic: item.topic,\n    category: item.category,\n    row_number: item.row_number,\n    prompt: `Создай карусель из 5-7 слайдов на тему: ${item.topic}\\n\\nКатегория: ${item.category}\\n\\nФормат JSON с полями: title, slides (array with text, hook), cta, hashtags`\n  }\n}];"
      },
