      "parameters": {
        "jsCode": "// Получаем историю постов для контекста\nconst newsItems = $('Code5').all();\nconst publishedPosts = $input.all();\n\n// Берем последние 10 опубликованных постов для анализа\nconst recentPosts = publishedPosts.slice(-10).map(p => p.json.content).join('\\n---\\n');\n\n// Берем первую новость для обработки\nconst newsItem = newsItems[0]?.json || {};\n\nreturn [{\n  json: {\n    news: newsItem,\n    recentPosts: recentPosts,\n    newsTitle: newsItem.title || '',\n    newsSummary: newsItem.summary || '',\n    newsUrl: newsItem.url || '',\n    newsId: newsItem.id || ''\n  }\n}];"
      },
