# Google Sheets Configuration
GOOGLE_SHEET_ID=your_sheet_id_here

# Threads API Configuration
THREADS_API_URL=https://graph.threads.net/v1.0
THREADS_USER_ID=your_threads_user_id

# GitHub Configuration
GITHUB_OWNER=your_github_username
GITHUB_REPO=ai-content-prompts
GITHUB_PROMPTS_URL=https://raw.githubusercontent.com/your_github_username/ai-content-prompts/main
GITHUB_REPO_FILE_ID=file_id_for_prompts

# OAuth Configuration
OAUTH_TOKEN_URL=https://your-oauth-provider.com/token
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
REFRESH_TOKEN=your_initial_refresh_token

# Telegram Bot Configuration
TELEGRAM_MONITORING_CHAT_ID=your_monitoring_chat_id
TELEGRAM_REVIEW_CHAT_ID=your_review_chat_id
TELEGRAM_BOT_TOKEN=your_bot_token

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# n8n Configuration
N8N_HOST=https://your-n8n-instance.com
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
